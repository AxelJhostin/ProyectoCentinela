---
import '../styles/global.css';
import { SITE_NAME, SITE_URL } from '../consts/seo';

interface Props {
  title: string;
  description: string;
  keywords?: string[];
  ogType?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  keywords = [],
  ogType = 'website',
  jsonLd,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('/app_icon.png', Astro.site).href;
const keywordContent = keywords.join(', ');
const jsonLdBlocks = jsonLd
  ? Array.isArray(jsonLd)
    ? jsonLd
    : [jsonLd]
  : [];
---

<!doctype html>
<html lang="es-EC">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {keywordContent && <meta name="keywords" content={keywordContent} />}
    <meta name="author" content={SITE_NAME} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="googlebot" content="index, follow" />
    <meta name="theme-color" content="#2563EB" />
    <meta name="application-name" content={SITE_NAME} />
    <meta name="geo.region" content="EC-M" />
    <meta name="geo.placename" content="Jipijapa, Manabí, Ecuador" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/app_icon.png" />
    <link rel="apple-touch-icon" href="/app_icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />

    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content="Logo de Centinela — alertas comunitarias" />
    <meta property="og:locale" content="es_EC" />
    <meta property="og:locale:alternate" content="es_ES" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap"
      rel="stylesheet"
    />

    {
      jsonLdBlocks.map((block) => (
        <script type="application/ld+json" set:html={JSON.stringify(block)} />
      ))
    }
  </head>
  <body>
    <slot />
  </body>
</html>
